# Server
PORT=3012
NODE_ENV=development

# Database (Docker configuration)
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=aiquiz
DB_PASSWORD=aiquiz_password
DB_DATABASE=aiquiz
DB_SYNCHRONIZE=true

# Redis (Docker configuration)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=aiquiz_redis_password

# JWT
JWT_SECRET=ai-quiz-super-secret-key-2026-change-in-production
JWT_EXPIRES_IN=7d

# CORS - Allow frontend on port 3010
CORS_ORIGIN=http://localhost:3010

# Google OAuth
GOOGLE_CLIENT_ID=YOUR_GOOGLE_CLIENT_ID
GOOGLE_CLIENT_SECRET=YOUR_GOOGLE_CLIENT_SECRET
GOOGLE_CALLBACK_URL=http://localhost:3012/api/v1/auth/google/callback

# Resend Email (Forgot Password)
RESEND_API_KEY=YOUR_RESEND_API_KEY
RESEND_DOMAIN=quiz.profitbenefit.com
FROM_EMAIL=noreply@quiz.profitbenefit.com
